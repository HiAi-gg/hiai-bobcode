# Bob local secrets — COPY to ./bob.env and fill in. bob.env is GITIGNORED, never commit it.
# Sourced by ./run-bob.sh before launching the fork from source.
#
# Model-provider creds do NOT go here — they live in the mimocode auth store
# (~/.local/share/mimocode/auth.json, managed by `/connect` in the TUI or `bob auth login`).
#
# These two are ONLY for the on-demand CLI skills (firecrawl-cli, context7) which read env vars.
# Get keys from: firecrawl.dev  /  context7.com

export FIRECRAWL_API_KEY=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
export CONTEXT7_API_KEY=ctx7sk-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
