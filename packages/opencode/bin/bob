#!/usr/bin/env bun

import { existsSync, readFileSync, realpathSync } from "fs"
import { dirname, join } from "path"
import os from "os"

function run(target) {
  const result = Bun.spawnSync([target, ...process.argv.slice(2)], {
    stdio: ["inherit", "inherit", "inherit"],
  })
  const code = typeof result.exitCode === "number" ? result.exitCode : 0
  process.exit(code)
}

const envPath = process.env.MIMOCODE_BIN_PATH
if (envPath) {
  run(envPath)
}

const scriptPath = realpathSync(__filename)
const scriptDir = dirname(scriptPath)

//
const cached = join(scriptDir, ".bob-cache")
const legacyCached = join(scriptDir, ".mimocode")
const resolvedCache = existsSync(cached) ? cached : existsSync(legacyCached) ? legacyCached : null
if (resolvedCache) {
  run(resolvedCache)
}

const platformMap = {
  darwin: "darwin",
  linux: "linux",
  win32: "windows",
}
const archMap = {
  x64: "x64",
  arm64: "arm64",
  arm: "arm",
}

let targetPlatform = platformMap[os.platform()]
if (!targetPlatform) {
  targetPlatform = os.platform()
}
let targetArch = archMap[os.arch()]
if (!targetArch) {
  targetArch = os.arch()
}
const base = "hiai-bob-" + targetPlatform + "-" + targetArch
const binary = targetPlatform === "windows" ? "bob.exe" : "bob"

function supportsAvx2() {
  if (targetArch !== "x64") return false

  if (targetPlatform === "linux") {
    try {
      return /(^|\s)avx2(\s|$)/i.test(readFileSync("/proc/cpuinfo", "utf8"))
    } catch {
      return false
    }
  }

  if (targetPlatform === "darwin") {
    try {
      const result = Bun.spawnSync(["sysctl", "-n", "hw.optional.avx2_0"], {
        stdio: ["inherit", "pipe", "pipe"],
        timeout: 1500,
      })
      if (result.exitCode !== 0) return false
      return (result.stdout?.toString() || "").trim() === "1"
    } catch {
      return false
    }
  }

  if (targetPlatform === "windows") {
    const cmd =
      '(Add-Type -MemberDefinition "[DllImport(""kernel32.dll"")] public static extern bool IsProcessorFeaturePresent(int ProcessorFeature);" -Name Kernel32 -Namespace Win32 -PassThru)::IsProcessorFeaturePresent(40)'

    for (const exe of ["powershell.exe", "pwsh.exe", "pwsh", "powershell"]) {
      try {
        const result = Bun.spawnSync([exe, "-NoProfile", "-NonInteractive", "-Command", cmd], {
          stdio: ["inherit", "pipe", "pipe"],
          timeout: 3000,
        })
        if (result.exitCode !== 0) continue
        const out = (result.stdout?.toString() || "").trim().toLowerCase()
        if (out === "true" || out === "1") return true
        if (out === "false" || out === "0") return false
      } catch {
        continue
      }
    }

    return false
  }

  return false
}

const names = (() => {
  const avx2 = supportsAvx2()
  const baseline = targetArch === "x64" && !avx2

  if (targetPlatform === "linux") {
    const musl = (() => {
      try {
        if (existsSync("/etc/alpine-release")) return true
      } catch {
        // ignore
      }

      try {
        const result = Bun.spawnSync(["ldd", "--version"], { stdio: ["inherit", "pipe", "pipe"] })
        const text = ((result.stdout?.toString() || "") + (result.stderr?.toString() || "")).toLowerCase()
        if (text.includes("musl")) return true
      } catch {
        // ignore
      }

      return false
    })()

    if (musl) {
      if (targetArch === "x64") {
        if (baseline) return [`${base}-baseline-musl`, `${base}-musl`, `${base}-baseline`, base]
        return [`${base}-musl`, `${base}-baseline-musl`, base, `${base}-baseline`]
      }
      return [`${base}-musl`, base]
    }

    if (targetArch === "x64") {
      if (baseline) return [`${base}-baseline`, base, `${base}-baseline-musl`, `${base}-musl`]
      return [base, `${base}-baseline`, `${base}-musl`, `${base}-baseline-musl`]
    }
    return [base, `${base}-musl`]
  }

  if (targetArch === "x64") {
    if (baseline) return [`${base}-baseline`, base]
    return [base, `${base}-baseline`]
  }
  return [base]
})()

function findBinary(startDir) {
  let current = startDir
  for (;;) {
    const modules = join(current, "node_modules")
    if (existsSync(modules)) {
      for (const name of names) {
        const candidate = join(modules, name, "bin", binary)
        if (existsSync(candidate)) return candidate
      }
    }
    const parent = dirname(current)
    if (parent === current) {
      return
    }
    current = parent
  }
}

//
// Development fallback: if we are running from the source repo (i.e. the
// compiled platform binary is not installed) and `src/index.ts` is present
// next to this script's parent directory (the package root), spawn
// `bun run --conditions=browser src/index.ts` with all passed args. This
// lets contributors run `bin/bob` directly from a clone of the repo
// without needing a published platform binary.
//
const packageRoot = dirname(scriptDir)

//
// Check for locally-built binary first (e.g. after `bun run build`).
//
const distDir = join(packageRoot, "dist")
for (const name of names) {
  const candidate = join(distDir, name, "bin", binary)
  if (existsSync(candidate)) {
    run(candidate)
  }
}

const sourceEntry = join(packageRoot, "src", "index.ts")
if (existsSync(sourceEntry)) {
  const result = Bun.spawnSync(["bun", "run", "--conditions=browser", sourceEntry, ...process.argv.slice(2)], {
    stdio: ["inherit", "inherit", "inherit"],
    cwd: packageRoot,
  })
  const code = typeof result.exitCode === "number" ? result.exitCode : 0
  process.exit(code)
}

const resolved = findBinary(scriptDir)
if (!resolved) {
  console.error(
    "It seems that your package manager failed to install the right version of the hiai-bob CLI for your platform. You can try manually installing " +
      names.map((n) => `\"${n}\"`).join(" or ") +
      " package",
  )
  process.exit(1)
}

run(resolved)
