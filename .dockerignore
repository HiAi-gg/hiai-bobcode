# Secrets and env
bob.env
.env
.env.*
*.local.env

# VCS
.git
.gitignore

# Dependencies (re-installed inside image)
node_modules
**/node_modules

# Build outputs
dist
**/dist
.ts-dist
*.tsbuildinfo

# Re-include patches (bun install applies these via package.json patches field)
!patches

# Dev/IDE
.dev-home
.vscode
.idea
.zed
*.swp
*.swo
*~
.DS_Store

# Agent state (local only)
.bob
.opencode
.mimocode
.claude

# Logs
*.log
logs
**/*.log

# Test artifacts
coverage
**/coverage
tests
**/tests
qa

# Docker dev
docker-compose.yml

# Misc
tmp
temp
.cache
.turbo

# Excluded workspaces (not built in Docker image)
packages/desktop/
packages/app/
packages/storybook/
packages/slack/
sdks/
*.tar.gz
*.zip

# Re-include package.json files from excluded workspace dirs so workspace
# lockfile resolution and the Dockerfile COPY steps see them in the build
# context (Docker's buildkit is content-aware, but workspace tooling needs
# the manifest to exist on disk).
!packages/app/package.json